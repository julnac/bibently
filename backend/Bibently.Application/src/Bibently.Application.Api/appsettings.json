{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
                "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Warning",
                "Microsoft.AspNetCore.Routing.Matching": "Warning",
                "Microsoft.AspNetCore.Mvc": "Warning",
                "System": "Warning"
            }
        }
    },
    "AllowedHosts": "*",
    "Cors": {
        "AllowedOrigins": [
            "https://bibently.com"
        ]
    },
    "RateLimiting": {
        "Global": {
            "PermitLimit": 30,
            "WindowMinutes": 1
        },
        "Strict": {
            "PermitLimit": 10,
            "WindowMinutes": 1
        }
    },
    "PrivateServer": {
        "BaseUrl": "https://ps.bibently.com",
        "BearerToken": "example-bearer-token"
    }
}